  "version": "1.0.0",
  "author": "Quomodosoft",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "tailwind:dev": "npx tailwindcss -i ./input.css -o ./assets/css/output.css --watch",
