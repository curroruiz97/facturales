    { "source": "/billing/cancel.html", "destination": "/billing/cancel", "permanent": true },
    { "source": "/aviso-legal.html", "destination": "/aviso-legal", "permanent": true },
    { "source": "/condiciones-legales.html", "destination": "/condiciones-legales", "permanent": true },
    { "source": "/politica-de-cookies.html", "destination": "/politica-de-cookies", "permanent": true },
    { "source": "/politica-de-privacidad.html", "destination": "/politica-de-privacidad", "permanent": true }
  ],
  "rewrites": [
    { "source": "/:path((?!.*\\.).*)", "destination": "/index.html" }
  ]
}
