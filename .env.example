# Supabase Configuration
# Copy this file to .env and fill in your actual values
# Get these values from: https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/api

VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================================
# Stripe — Edge Functions environment variables
# Set these in Supabase Dashboard > Settings > Edge Functions > Environment Variables
# They are NOT used by the frontend (Vite) — only by Edge Functions.
# ============================================================

# Stripe secret key (sk_test_... for test mode, sk_live_... for production)
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret (whsec_...)
# Get this from Stripe Dashboard > Developers > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for each plan/interval combination
# Create these in Stripe Dashboard > Products > Add product > Add price
# Starter plan (0 EUR)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...

# Pro plan (19 EUR/month, 15 EUR/month billed yearly)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# Business plan (49 EUR/month, 39 EUR/month billed yearly)
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_YEARLY=price_...

# Public URL of the app (used for Stripe success/cancel redirects)
APP_URL=https://facturales.es
